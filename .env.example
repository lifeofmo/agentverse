# Copy to .env and fill in real values before deploying.
# Never commit .env to version control.

# ── Secrets (MUST change for production) ─────────────────────────────────────
JWT_SECRET=agentverse-dev-secret-CHANGE-IN-PROD
POSTGRES_PASSWORD=agentverse-dev-CHANGE-IN-PROD

# ── Public-facing URLs (what the browser connects to) ─────────────────────────
# Local dev:
PUBLIC_API_URL=http://localhost:8000
PUBLIC_WS_URL=ws://localhost:8000/ws

# Production example:
# PUBLIC_API_URL=https://api.agentverse.io
# PUBLIC_WS_URL=wss://api.agentverse.io/ws

# ── Backend internal self-reference ───────────────────────────────────────────
# Used when a pipeline registers itself as an agent endpoint
API_BASE_URL=http://backend:8000

# ── Demo agent server ─────────────────────────────────────────────────────────
# Docker: http://agents:8001  |  Local dev: http://127.0.0.1:8001
AGENT_SERVER_URL=http://127.0.0.1:8001

# ── CORS (comma-separated origins, or * for dev) ─────────────────────────────
# Production: set to your actual frontend domain(s)
# CORS_ORIGINS=https://agentverse.io,https://www.agentverse.io
CORS_ORIGINS=*

# ── x402 HTTP Payment Protocol ────────────────────────────────────────────────
# https://x402.org  |  Enables real USDC micropayments on Base
# Agents with an Ethereum owner_wallet (0x...) will require x402 payment.
# Agents without an owner_wallet continue using the internal credits system.
#
# To enable on Base Sepolia (testnet — use test USDC, not real money):
#   1. Set X402_ENABLED=true
#   2. Set X402_NETWORK=base-sepolia  (already default)
#   3. Fund your agent wallet on Base Sepolia with test USDC:
#      https://faucet.circle.com  (select "Base Sepolia")
#   4. Register an agent with your 0x wallet address as owner_wallet
#
# Safety limits enforced by the backend:
#   - Max price per call: $10.00 USD
#   - Wallet format: must be valid 0x+40hex Ethereum address
#   - Replay protection: each payment proof can only be used once
#   - Facilitator timeout: 8 seconds; returns 503 if unreachable
X402_ENABLED=false
# base-sepolia for testing (testnet), base-mainnet for production (real USDC)
X402_NETWORK=base-sepolia
# Coinbase's hosted facilitator (or self-host: https://github.com/coinbase/x402)
X402_FACILITATOR=https://x402.org/facilitator
